{
  "repo_name": "rmap",
  "purpose": "Builds a queryable repository map to provide focused context for coding agents.",
  "stack": "TypeScript, Node.js",
  "languages": [
    "TypeScript",
    "Shell"
  ],
  "entrypoints": [
    "src/index.ts",
    "src/cli/index.ts"
  ],
  "modules": [
    {
      "path": "src/cli",
      "description": "CLI commands and terminal UI"
    },
    {
      "path": "src/config",
      "description": "Configuration and environment management"
    },
    {
      "path": "src/coordinator",
      "description": "Pipeline orchestration and state management"
    },
    {
      "path": "src/core",
      "description": "Shared utilities and LLM provider integration"
    },
    {
      "path": "src/levels",
      "description": "Multi-stage code analysis pipeline"
    },
    {
      "path": "src/query",
      "description": "Query engine for the repository map"
    }
  ],
  "config_files": [
    "package.json",
    "tsconfig.json",
    "tsup.config.ts",
    ".env",
    "rmap.yaml"
  ],
  "conventions": [
    "Tests mirror src/ structure in tests/ directory",
    "Use barrel exports (index.ts) for module interfaces",
    "Manage environment variables through src/config/env.ts",
    "Implement new LLM providers in src/core/providers/"
  ]
}
