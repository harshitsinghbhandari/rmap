{
  "name": "rmap",
  "version": "1.0.0",
  "description": "A semantic repository map builder for coding agents. Generates structured, queryable maps of codebases to provide context-aware file selection and dependency understanding.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "bin": {
    "rmap": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "tsx --test $(find tests -name '*.test.ts')",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "repository",
    "codebase",
    "semantic-map",
    "coding-agent",
    "ai-tools",
    "context-generation",
    "code-analysis"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshitsinghbhandari/rmap.git"
  },
  "bugs": {
    "url": "https://github.com/harshitsinghbhandari/rmap/issues"
  },
  "homepage": "https://github.com/harshitsinghbhandari/rmap#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.15",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
