{
  "name": "rmap",
  "version": "0.1.0",
  "description": "A semantic repository map builder for coding agents. Generates structured, queryable maps of codebases to provide context-aware file selection and dependency understanding.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./core": {
      "import": "./dist/core/index.mjs",
      "types": "./dist/core/index.d.mts"
    },
    "./config": {
      "import": "./dist/config/index.mjs",
      "types": "./dist/config/index.d.mts"
    }
  },
  "bin": {
    "rmap": "./dist/cli/index.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "NODE_ENV=test tsx --test $(find tests -name '*.test.ts')",
    "test:coverage": "NODE_ENV=test c8 --reporter=text --reporter=lcov tsx --test $(find tests -name '*.test.ts')",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "repository",
    "codebase",
    "semantic-map",
    "coding-agent",
    "ai-tools",
    "context-generation",
    "code-analysis"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshitsinghbhandari/rmap.git"
  },
  "bugs": {
    "url": "https://github.com/harshitsinghbhandari/rmap/issues"
  },
  "homepage": "https://github.com/harshitsinghbhandari/rmap#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@clack/prompts": "^1.2.0",
    "@google/genai": "^1.48.0",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "ignore": "^7.0.5",
    "log-update": "^8.0.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.17.15",
    "c8": "^11.0.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2"
  }
}
